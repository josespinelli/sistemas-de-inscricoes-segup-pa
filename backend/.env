# ============================================================
# Variáveis de ambiente — copie para .env e ajuste os valores
# ============================================================

# Porta em que a aplicação irá subir
SERVER_PORT=8080

# Host do banco de dados
DB_HOST=mysql

# Porta do banco de dados
DB_PORT=3306

# Nome do banco (será criado automaticamente se não existir)
DB_NAME=segup_inscricoes

# Usuário do banco de dados
DB_USER=root

# Senha do banco de dados
DB_PASS=root
